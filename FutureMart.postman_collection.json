{
  "info": {
    "name": "FutureMart API",
    "description": "Multi-Vendor Order & Inventory Management Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "adminToken", "value": "" },
    { "key": "vendorToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "vendorId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register/customer",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Customer\",\n  \"email\": \"testcustomer@example.com\",\n  \"password\": \"Customer@123\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Register Vendor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register/vendor",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Vendor\",\n  \"email\": \"newvendor@example.com\",\n  \"password\": \"Vendor@123\",\n  \"businessName\": \"New Vendor Shop\",\n  \"businessDescription\": \"We sell quality products\"\n}"
            }
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('adminToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@futuremart.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "Login - Vendor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('vendorToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"techstore@futuremart.com\",\n  \"password\": \"Vendor@123\"\n}"
            }
          }
        },
        {
          "name": "Login - Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('customerToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rahul@example.com\",\n  \"password\": \"Customer@123\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh-token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"YOUR_REFRESH_TOKEN_HERE\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        },
        {
          "name": "Get All Vendors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/vendors?vendorStatus=pending&page=1&limit=10",
              "query": [
                { "key": "vendorStatus", "value": "pending" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Approve Vendor",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/vendors/{{vendorId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            }
          }
        },
        {
          "name": "Reject Vendor",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/admin/vendors/{{vendorId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\"\n}"
            }
          }
        },
        {
          "name": "All Stock Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/stock-logs?page=1&limit=20"
          }
        },
        {
          "name": "All Orders (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/orders/all?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product (Vendor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.product) {",
                  "  pm.collectionVariables.set('productId', res.data.product._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productName\": \"Smart Watch Pro\",\n  \"description\": \"Feature-rich smartwatch with health monitoring, GPS and 5-day battery.\",\n  \"price\": 8999,\n  \"discountPrice\": 7499,\n  \"stock\": 25,\n  \"sku\": \"TECH-WATCH-009\",\n  \"category\": \"Electronics\",\n  \"status\": \"active\"\n}"
            }
          }
        },
        {
          "name": "Update Product (Vendor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 9499,\n  \"discountPrice\": 7999,\n  \"stock\": 30\n}"
            }
          }
        },
        {
          "name": "Delete Product (Vendor)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "My Products (Vendor)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/products/vendor/my-products?page=1&limit=10&status=active",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "active" }
              ]
            }
          }
        },
        {
          "name": "All Active Products (Customer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=10&category=Electronics&sortBy=price&sortOrder=asc",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "category", "value": "Electronics" },
                { "key": "sortBy", "value": "price" },
                { "key": "sortOrder", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/products?search=earphone&page=1&limit=10",
              "query": [
                { "key": "search", "value": "earphone" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Single Product",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Admin Adjust Stock",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/products/{{productId}}/stock",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stock\": 100,\n  \"note\": \"Restocked after audit\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.order) {",
                  "  pm.collectionVariables.set('orderId', res.data.order._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 1\n    }\n  ],\n  \"address\": {\n    \"street\": \"123 MG Road\",\n    \"city\": \"Delhi\",\n    \"state\": \"Delhi\",\n    \"pincode\": \"110001\"\n  },\n  \"paymentStatus\": \"paid\"\n}"
            }
          }
        },
        {
          "name": "My Orders (Customer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/orders/my-orders?page=1&limit=10"
          }
        },
        {
          "name": "Vendor Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": "{{baseUrl}}/orders/vendor-orders?page=1&limit=10"
          }
        },
        {
          "name": "Confirm Order (Vendor)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{vendorToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderStatus\": \"confirmed\"\n}"
            }
          }
        },
        {
          "name": "Cancel Order (Customer)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/orders/{{orderId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderStatus\": \"cancelled\",\n  \"cancelReason\": \"Changed my mind\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Stock Logs",
      "item": [
        {
          "name": "Vendor Stock Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/stock-logs/vendor?page=1&limit=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Vendor Stock Logs - by Product",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/stock-logs/vendor?productId={{productId}}",
              "query": [{ "key": "productId", "value": "{{productId}}" }]
            }
          }
        }
      ]
    }
  ]
}
